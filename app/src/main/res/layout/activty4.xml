<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F5F9"
    android:orientation="vertical">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <Button
            android:id="@+id/bacc"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:background="@drawable/ctrelra"
            android:src="@android:color/transparent"
            />
        <Button
            android:id="@+id/go"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginTop="7dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="2dp"
            android:background="@drawable/img"
            android:src="@android:color/transparent"
            />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Результаты проверки"
            android:textColor="#1A2634"
            android:textSize="18sp" />

        <View
            android:layout_width="12dp"
            android:layout_height="18dp"
            android:background="@drawable/down"
            android:layout_marginTop="7dp"
            />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


        <androidx.cardview.widget.CardView
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:layout_gravity="center"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_uniqueness_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Уникальность"
                            android:textColor="#5B6E8C"
                            android:textSize="10sp"
                            />

                        <TextView
                            android:id="@+id/tv_uniqueness_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="77%"
                            android:textColor="#00AE03"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginStart="35dp"/>


                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_grade"
                        android:layout_width="0dp"
                        android:layout_height="19dp"
                        android:layout_weight="1"
                        android:background="#F5F89B"
                        android:gravity="center"
                        android:text="Среднее"
                        android:textColor="@color/black"
                        android:textSize="10sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="77"
                    android:progressTint="#00AE03"
                    android:progressBackgroundTint="#C5C5C5" />

                <LinearLayout
                    android:id="@+id/warning_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="15dp"
                        android:layout_height="13dp"
                        android:background="@drawable/mis"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tv_warning"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Обнаружены совпадения с внешними источниками."
                        android:textColor="#C2410C"
                        android:textSize="12sp"
                        android:layout_marginStart="5dp"
                        android:layout_marginTop="-5dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


            <LinearLayout
                android:id="@+id/row1"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginStart="20dp"
                android:orientation="horizontal">


                <LinearLayout
                    android:layout_width="103dp"
                    android:layout_height="57dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/butt1"
                        android:layout_width="match_parent"
                        android:layout_height="57dp"
                        android:background="@drawable/corner4"
                        android:contentDescription="@android:string/yes"
                        app:backgroundTint="@null"/>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="16dp"
                        android:text="23%"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:layout_marginTop="-45dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_marginStart="27dp"
                        android:layout_marginTop="2dp"
                        android:text="Плагиат"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="103dp"
                    android:layout_height="57dp"
                    android:layout_marginStart="20dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/m"
                        android:layout_width="match_parent"
                        android:layout_height="57dp"
                        android:background="@drawable/corner4"
                        android:contentDescription="@android:string/yes"
                        app:backgroundTint="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="16dp"
                        android:layout_marginTop="-45dp"
                        android:layout_gravity="center"
                        android:text="3"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_marginStart="25dp"
                        android:layout_marginTop="2dp"
                        android:text="Источников"
                        android:textSize="11sp" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="103dp"
                    android:layout_height="57dp"
                    android:orientation="vertical"
                   android:layout_marginStart="15dp">


                    <Button
                        android:id="@+id/md"
                        android:layout_width="match_parent"
                        android:layout_height="57dp"
                        android:background="@drawable/corner4"
                        android:contentDescription="@android:string/yes"
                        app:backgroundTint="@null"/>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="16dp"
                        android:layout_marginTop="-45dp"
                        android:layout_gravity="center"
                        android:text="2,847"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="2dp"
                        android:text="Слов"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="10dp"
               >

                <Button
                    android:id="@+id/btn_new_check"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/corners"
                    app:backgroundTint="@null"
                    android:text="Обзор"
                    android:textColor="@color/black"
/>

                <Button
                    android:id="@+id/btn_save_report"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@android:color/transparent"
                    android:strokeColor="#CBDDE9"
                    android:text="Источники (3)"
                    android:textAllCaps="false"
                    android:textColor="#1F6392" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                android:layout_gravity="center"
                app:cardElevation="2dp"
                android:layout_marginBottom="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="340dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_uniqueness"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Распределение текста"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:textSize="10sp"
                                />

                            <TextView
                                android:id="@+id/tv_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="77%"
                                android:textColor="#00AE03"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginStart="260dp"/>


                        </LinearLayout>


                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_bar2"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:max="100"
                        android:progress="77"
                        android:progressTint="#00AE03"
                        android:progressBackgroundTint="#C5C5C5" />
                    <TextView
                        android:id="@+id/tv_percent23"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="23%"
                        android:textColor="#FFA509"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginStart="260dp"/>
                    <ProgressBar
                        android:id="@+id/progress_bar3"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:max="100"
                        android:progress="23"
                        android:progressTint="#FFA509"
                        android:progressBackgroundTint="#C5C5C5" />


                </LinearLayout>
            </androidx.cardview.widget.CardView>



        <androidx.cardview.widget.CardView
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            android:layout_marginStart="20dp"
            app:cardElevation="2dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#F0F6FA">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#E7FFFD">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="18dp"
                        android:background="@drawable/lamp"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Рекомендации"
                        android:textColor="#1F3B4C"
                        android:textSize="16sp"
                        android:layout_marginTop="-5dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="100dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginStart="-120dp"
                        android:text="Перефразируйте найденные совпадения\nДобавьте ссылки на использованные источники\nИспользуйте цитаты для прямых заимствований"
                        android:textColor="#1F3B4C"
                        android:textSize="12sp"
                        android:lineSpacingExtra="15dp"

                        />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/recommendations_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>


    </LinearLayout>
</ScrollView>
</LinearLayout>